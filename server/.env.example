# MongoDB connection string
# Local:  mongodb://localhost:27017/intervue
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/intervue
MONGO_URI=mongodb://localhost:27017/intervue

# JWT secret — use a long random string in production
JWT_SECRET=your_jwt_secret_here_change_me

# Server port
PORT=5000

# Google Gemini API key (for AI question generation & evaluation)
GEMINI_API_KEY=your_gemini_api_key_here
